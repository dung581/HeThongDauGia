<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: Skyblue;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Client.danhSachDauGiaController">

    <children>

        <!-- Title -->
        <Label layoutX="260" layoutY="20" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Danh sách phiên đấu giá" />

        <!-- Image -->
        <ImageView fx:id="sideImage" fitHeight="220" fitWidth="220" layoutX="40" layoutY="80">
         <image>
            <Image url="@hinh-meme-meo-dap-mat-na.jpg" />
         </image></ImageView>

        <!-- Main card -->
        <VBox layoutX="300" layoutY="80" prefHeight="350" prefWidth="420" spacing="15" style="-fx-background-color: #ffffff; -fx-background-radius: 10;">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <!-- Top actions -->
            <HBox alignment="CENTER_LEFT" spacing="10">

                <Button fx:id="refreshBtn" prefWidth="90" style="-fx-background-color: #5dade2; -fx-text-fill: white;" text="Refresh" />

                <!-- Dropdown filter -->
                <ComboBox fx:id="filterComboBox" prefWidth="150" promptText="Chọn Vật Phẩm">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="All" />
                            <String fx:value="A" />
                            <String fx:value="B" />
                            <String fx:value="C" />
                            <String fx:value="D" />
                        </FXCollections>
                    </items>
                </ComboBox>

                <Label fx:id="statusLiveLabel" style="-fx-text-fill: gray;" text="Ready" />

            </HBox>

            <!-- Session list -->
            <ScrollPane fitToWidth="true" prefHeight="250" style="-fx-background-color: transparent;">
                <content>
                    <VBox fx:id="sessionsContainer" spacing="10" />
                </content>
            </ScrollPane>

        </VBox>
      <Button layoutX="40.0" layoutY="21.0" mnemonicParsing="false" onAction="#trolai" text="Trở Lại" />

    </children>
</AnchorPane>
