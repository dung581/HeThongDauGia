<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="520.0" prefWidth="900.0" style="-fx-background-color: skyblue;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Client.AccountController">
   <top>
      <HBox alignment="CENTER_LEFT" spacing="16.0" style="-fx-padding: 12;" BorderPane.alignment="CENTER">
         <children>
            <Button mnemonicParsing="false" onAction="#backToDashboard" text="Quay lai" />
            <Label fx:id="lblTitle" text="Thong tin tai khoan">
               <font>
                  <Font size="20.0" />
               </font>
            </Label>
         </children>
      </HBox>
   </top>

   <center>
      <VBox spacing="14.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="18.0" left="18.0" right="18.0" top="8.0" />
         </padding>

         <VBox fx:id="userInfoPane" spacing="10.0" style="-fx-background-color: white; -fx-padding: 14; -fx-background-radius: 8;">
            <children>
               <Label text="Username:" />
               <Label fx:id="lblUsername" text="" />
               <Label text="Ho ten:" />
               <Label fx:id="lblFullname" text="" />
               <Label text="Role:" />
               <Label fx:id="lblRole" text="" />
               <Label text="Tong so du:" />
               <Label fx:id="lblBalance" text="0" />
               <Label text="Tien dang khoa:" />
               <Label fx:id="lblLocked" text="0" />
               <Label text="So du kha dung:" />
               <Label fx:id="lblAvailable" text="0" />
            </children>
         </VBox>

         <VBox fx:id="adminPane" spacing="10.0" visible="false" managed="false" style="-fx-background-color: white; -fx-padding: 14; -fx-background-radius: 8;">
            <children>
               <Label text="Danh sach tai khoan quan ly" />
               <TableView fx:id="adminTable" prefHeight="360.0">
                  <columns>
                     <TableColumn fx:id="colUserId" prefWidth="80.0" text="User ID" />
                     <TableColumn fx:id="colUsername" prefWidth="150.0" text="Username" />
                     <TableColumn fx:id="colFullname" prefWidth="170.0" text="Fullname" />
                     <TableColumn fx:id="colRole" prefWidth="100.0" text="Role" />
                     <TableColumn fx:id="colBalance" prefWidth="140.0" text="Balance" />
                     <TableColumn fx:id="colLocked" prefWidth="140.0" text="Locked" />
                  </columns>
               </TableView>
            </children>
         </VBox>
      </VBox>
   </center>
</BorderPane>
