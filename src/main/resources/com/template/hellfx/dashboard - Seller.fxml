<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="520.0" prefWidth="900.0" style="-fx-background-color: Skyblue;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Client.dashboardController">
   <center>
      <HBox alignment="CENTER" spacing="24.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
         </padding>

         <StackPane prefWidth="420.0">
            <children>
               <ImageView fitHeight="320.0" fitWidth="320.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                     <Image url="@hinh-meme-meo-dap-mat-na.jpg" />
                  </image>
               </ImageView>
            </children>
         </StackPane>

         <Separator orientation="VERTICAL" prefHeight="460.0" />

         <VBox alignment="CENTER" spacing="14.0" prefWidth="280.0">
            <children>
               <Button mnemonicParsing="false" onAction="#dangban" prefHeight="36.0" prefWidth="200.0" text="Đăng bán" />
               <Button mnemonicParsing="false" onAction="#quanlytk" prefHeight="36.0" prefWidth="200.0" text="Thông tin tài khoản" />
               <Button mnemonicParsing="false" onAction="#goToLogin" prefHeight="36.0" prefWidth="200.0" style="-fx-background-color: red; -fx-text-fill: white;" text="Đăng xuất" />
            </children>
         </VBox>
      </HBox>
   </center>
</BorderPane>
