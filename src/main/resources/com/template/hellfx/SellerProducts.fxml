<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="560.0" prefWidth="980.0" style="-fx-background-color: skyblue;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Client.SellerProductController">
   <top>
      <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-padding: 12;" BorderPane.alignment="CENTER">
         <children>
            <Button mnemonicParsing="false" onAction="#backToSellerDashboard" text="Trở lại" />
            <Label text="Đăng bán sản phẩm" style="-fx-font-size: 20px;" />
         </children>
      </HBox>
   </top>

   <left>
      <VBox spacing="10.0" prefWidth="280.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 12;" BorderPane.alignment="CENTER">
         <padding><Insets bottom="12.0" left="12.0" right="12.0" top="12.0" /></padding>
         <children>
            <Label text="Tên sản phẩm" />
            <TextField fx:id="itemName" promptText="Nhập tên" />
            <Label text="Giá khởi điểm" />
            <TextField fx:id="itemPrice" promptText="Nhập giá" />
            <Label text="Mô tả" />
            <TextField fx:id="itemDescription" promptText="Nhập mô tả" />
            <Button mnemonicParsing="false" onAction="#submitItem" text="Gửi duyệt" />
         </children>
      </VBox>
   </left>

   <center>
      <VBox spacing="8.0" BorderPane.alignment="CENTER">
         <padding><Insets bottom="12.0" left="12.0" right="12.0" top="12.0" /></padding>
         <children>
            <Label text="Sản phẩm của tôi" style="-fx-font-size: 16px;" />
            <TableView fx:id="table" prefHeight="430.0">
               <columns>
                  <TableColumn fx:id="colId" prefWidth="80.0" text="ID" />
                  <TableColumn fx:id="colName" prefWidth="200.0" text="Tên" />
                  <TableColumn fx:id="colPrice" prefWidth="140.0" text="Giá" />
                  <TableColumn fx:id="colStatus" prefWidth="130.0" text="Trạng thái" />
                  <TableColumn fx:id="colReason" prefWidth="300.0" text="Lý do phản hồi" />
               </columns>
            </TableView>
            <Button mnemonicParsing="false" onAction="#loadMyItems" text="Tải lại" />
         </children>
      </VBox>
   </center>
</BorderPane>
